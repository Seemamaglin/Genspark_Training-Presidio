{
  "$schema": "https://angular.io/cli/config/schema.json",
  "version": 1,
  "defaultProject": "bus-booking-client",
  "projects": {
    "bus-booking-client": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/bus-booking-client",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "browserTarget": "bus-booking-client:build:production" },
            "development": { "browserTarget": "bus-booking-client:build:development" }
          },
          "defaultConfiguration": "development",
          "options": {
            "browserTarget": "bus-booking-client:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
